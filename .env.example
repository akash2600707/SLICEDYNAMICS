# Database (PostgreSQL)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/slicedynamics?schema=public"

# NextAuth
NEXTAUTH_SECRET="your-secret-here-run-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# AWS S3 / Cloudflare R2
AWS_ACCESS_KEY_ID="your-access-key"
AWS_SECRET_ACCESS_KEY="your-secret-key"
AWS_REGION="ap-south-1"
AWS_BUCKET_NAME="slicedynamics-uploads"

# For Cloudflare R2 (alternative to S3), add:
# AWS_ENDPOINT_URL="https://<ACCOUNT_ID>.r2.cloudflarestorage.com"

# Stripe
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
